/**
 * Project Menu Panel — full-screen overlay that looks like the menu window
 * Managed by ProjectsArea.js; shows project description when Projects area is open
 */

.project-menu-panel
    display none
    position fixed
    top 0
    left 0
    width 100%
    height 100%
    z-index 7
    align-items center
    justify-content center
    color #ffffff
    opacity 0
    transition opacity 0.3s
    font-family "Nunito", sans-serif
    overflow hidden

    &::before
        content ''
        position absolute
        top 0
        left 0
        width 100%
        height 100%
        background rgba(29, 23, 33, 0.75)
        backdrop-filter blur(6px)
        -webkit-backdrop-filter blur(6px)

    &.is-displayed
        display flex

    &.is-visible
        opacity 1

    .inner
        position relative
        width @css{ min(1000px, calc(100% - 120px)) }
        height @css{ min(600px, calc(100% - 120px)) }
        z-index 1

        @media only screen and (orientation portrait)
            top 22px
            width @css{ min(600px, calc(100% - 20px)) }
            height @css{ min(78vh, calc(100% - 90px)) }

        @media only screen and (max-width 440px)
            left 0
            width calc(100vw - 10px)

    // Close button — top-left above the inner container (always visible)
    .pm-close
        position absolute
        left 0
        bottom 100%
        margin-bottom 3px
        top auto
        width 44px
        height 44px
        z-index 2

        .button-inner
            position absolute
            top 0
            left 0
            width 100%
            height 100%
            background radial-gradient(ellipse at top right, #C21515, #46123B)
            transition transform 0.15s

            &::after
                content ''
                display block
                position absolute
                top 3px
                right 3px
                bottom 3px
                left 3px
                border 1px solid rgba(255, 255, 255, 0.35)

            .icon-container
                display flex
                position absolute
                align-items center
                justify-content center
                top 0
                right 0
                bottom 0
                left 0
                opacity 0.85

                img
                    width 14px
                    height 14px

        &:hover .button-inner
            transform scale(1.05)

    // Prev / Next navigation buttons (above the content side, like menu nav tabs)
    .project-menu-nav
        display flex
        position absolute
        left calc(50% + 10px)
        bottom 100%
        gap 3px

        @media only screen and (orientation portrait)
            left 10px

        @media only screen and (max-width 520px)
            left 0
            gap 1px

    .pm-nav-btn
        position relative
        width 58px
        height 44px
        cursor pointer

        .button-inner
            position absolute
            top 0
            left 0
            width 100%
            height calc(100% + 4px)
            background radial-gradient(ellipse at top right, #251f2b, #1d1721)
            transition transform 0.12s

            &::after
                content ''
                display block
                position absolute
                top 3px
                right 3px
                bottom 0
                left 3px
                border 1px solid rgba(255, 255, 255, 0.3)
                border-bottom none

            .icon-container
                display flex
                position absolute
                align-items center
                justify-content center
                top 0
                right 0
                bottom 0
                left 0
                color #ffffff
                font-size 18px
                font-weight 700
                opacity 0.65
                transition opacity 0.15s

        html:not(.is-mode-touch) &:hover
            .button-inner
                .icon-container
                    opacity 1

    // Main container: left panel (title) + right panel (content)
    .container
        position relative
        display flex
        width 100%
        height 100%

        @media only screen and (orientation portrait)
            flex-direction column

    // Left panel — project category + display title
    .pm-left
        position relative
        width 50%
        display flex
        flex-direction column
        align-items flex-start
        justify-content center
        padding 36px 40px
        background radial-gradient(ellipse at top left, #251f2b, #1d1721)
        overflow hidden

        &::after
            content ''
            position absolute
            top 3px
            right 3px
            bottom 3px
            left 3px
            border 1px solid rgba(255, 255, 255, 0.35)
            pointer-events none

        @media only screen and (orientation portrait)
            width auto
            height 35%
            padding 20px 24px

        @media only screen and (max-width 520px)
            padding 16px 20px

    .pm-category
        font-size 0.6em
        text-transform uppercase
        letter-spacing 0.16em
        color rgba(147, 147, 213, 0.75)
        margin-bottom 0.55em

    .pm-title
        font-family "Amatic SC", cursive
        font-size 1.55em
        font-weight 700
        line-height 1.25
        color #ffffff

        @media only screen and (max-width 520px)
            font-size 1.3em

    .pm-counter
        font-size 0.55em
        color rgba(255, 255, 255, 0.35)
        margin-top 1.4em
        letter-spacing 0.05em

    // Right panel — description text + link buttons
    .pm-right
        position relative
        width 50%
        background radial-gradient(ellipse at top left, #251f2b, #1d1721)
        overflow hidden

        @media only screen and (orientation portrait)
            width auto
            height 65%

    .pm-body
        position absolute
        top 0
        left 0
        width calc(100% + 20px)
        height 100%
        padding 28px 40px 40px 40px
        overflow-y auto
        overflow-x hidden
        scrollbar-width thin
        scrollbar-color rgba(147, 147, 213, 0.4) transparent

        @media only screen and (max-width 870px)
            padding 20px 30px 30px 30px

        @media only screen and (max-width 520px)
            padding 14px 20px 20px 20px

        p
            color rgba(255, 255, 255, 0.82)
            font-size 0.72em
            line-height 1.78
            margin-bottom 0.75em

            &:last-child
                margin-bottom 0

        p:first-child
            margin-top 0

/**
 * Styled link buttons for project URLs
 */
.project-link-btn
    display inline-block
    margin 6px 6px 0 0
    padding 5px 14px
    background rgba(147, 147, 213, 0.1)
    border 1px solid rgba(147, 147, 213, 0.32)
    border-radius 3px
    color #aaaaee
    font-family "Nunito", sans-serif
    font-size 0.65em
    text-decoration none
    cursor pointer
    transition background 0.2s, border-color 0.2s, color 0.2s
    line-height 1.6

    &:hover
        background rgba(147, 147, 213, 0.22)
        border-color rgba(147, 147, 213, 0.62)
        color #ffffff

/**
 * Shiny gradient inline link (used in Wasiu's Home panel)
 */
.shiny-link
    font-weight 700
    background linear-gradient(90deg, #9393d5, #d4a5ff, #ff9ecd, #9393d5)
    background-size 300% auto
    -webkit-background-clip text
    -webkit-text-fill-color transparent
    background-clip text
    animation shine-link 4s linear infinite
    cursor pointer
    text-decoration none

.inline-link
    color #aaaaee
    text-decoration underline
    text-underline-offset 3px
    transition color 0.2s

    &:hover
        color #ffffff

@keyframes shine-link
    to
        background-position 300% center

/**
 * Early loading notice — static HTML notification visible before JS loads
 */
.early-notice
    opacity 1 !important
    transform none !important
    pointer-events none

    .time-bar
        display none !important

html.is-started .early-notice
    display none !important

/**
 * Hide "Made with Replit" badge
 */
[data-testid="replit-badge"],
.replit-badge
    display none !important
